{
  "name": "electron-gallery",
  "private": true,
  "version": "3.36.0",
  "description": "A high-performance image gallery with scoring capabilities",
  "author": "Electron Image Scoring Team",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail \"npm run db:start\" \"npm run dev:web\" \"npm run dev:electron\"",
    "dev:web": "vite",
    "dev:electron": "wait-on tcp:5173 && tsc -p electron/tsconfig.json && cross-env ELECTRON_IS_DEV=1 electron .",
    "db:start": "powershell -ExecutionPolicy Bypass -File scripts/start_db.ps1",
    "build": "tsc -p electron/tsconfig.json && tsc -b && vite build && electron-packager . --overwrite --platform=win32 --arch=x64 --out=release-builds --prune=true",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:db": "cd ../image-scoring && python scripts/setup_test_db.py",
    "postinstall": "node scripts/patch-node-firebird.js"
  },
  "build": {
    "forceCodeSigning": false,
    "appId": "com.electron.gallery",
    "productName": "Electron Image Gallery",
    "win": {
      "icon": "public/icon.png",
      "target": "nsis",
      "verifyUpdateCodeSignature": false
    },
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "public/**/*"
    ]
  },
  "dependencies": {
    "@gradio/client": "^2.1.0",
    "electron-is-dev": "^3.0.1",
    "exiftool-vendored": "^35.11.0",
    "libraw-wasm": "^1.1.2",
    "lucide-react": "^0.563.0",
    "node-firebird": "^1.1.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-virtuoso": "^4.18.1",
    "sharp": "^0.34.5",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.1.0",
    "electron-builder": "24.13.3",
    "electron-packager": "^17.1.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "wait-on": "^9.0.3"
  }
}
